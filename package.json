    "zod": "^3.23.8",
    "react-hook-form": "^7.52.2",
    "@hookform/resolvers": "^3.9.0",
    "framer-motion": "^11.3.24",
    "lucide-react": "^0.427.0",
    "react-day-picker": "^9.0.8",
    "date-fns": "^3.6.0",
