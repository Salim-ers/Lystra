{
  "name": "lystra",
  "version": "0.1.0",
  "private": true,
  "description": "Lystra — marketplace premium de prestataires événementiels (Malt + Airbnb pour l'événementiel haut de gamme).",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
